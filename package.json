{
  "name": "opencode-usage-panel",
  "private": true,
  "version": "0.3.0-beta.1",
  "scripts": {
    "tauri": "tauri",
    "fmt:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "check:rust": "npm run fmt:rust && npm run lint:rust && npm run test:rust",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "chart.js": "^4.4.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0"
  }
}
